import std::io
import std::number::i64
import std::list
import std::string(concat)

def print_list (list::List<I64> -> !io::IO) \{
    defp inner_print_list (list::List<I64> -> !io::IO) \{
        match {
            list::Empty -> { " " io::print }
            list::List(element next) -> {
                " " io::print element i64::to_string io::print
                next inner_print_list
            }
        }
    }
    "[" io::print
    inner_print_list
    "]" io::print
}

def print_list_of_list (list::List<list::List<I64>> -> !io::IO) \{
    defp inner_print_list (list::List<list::List<I64>> -> !io::IO) \{
        match {
            list::Empty -> {}
            list::List(element next) -> {
                element print_list
                next inner_print_list
            }
        }
    }
    "[" io::print
    inner_print_list
    "]" io::print
}

    [1 2 3 4] print_list "\n" io::print
    [[1 2] [3 4]] print_list_of_list "\n" io::print
