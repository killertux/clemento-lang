import std::stack(swap drop)
import std::panic
import std::list

type Result<a b> {
    Ok(value a) Err(error b)
}

def map (Result<a b> (a -> c) -> Result<c b>) \{
    swap match {
        Ok(value) -> { value swap apply Ok }
        Err(error) -> { drop error Err }
    }
}

def unwrap (Result<a b> -> a !panic::Panic) \{
    match {
        Err -> { "unwrap an error" panic }
        Ok(value) -> value
    }
}
