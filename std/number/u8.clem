import std::list
import std::number::u64
import std::boolean(Boolean)

defx + (U8 U8 -> U8)
defx - (U8 U8 -> U8)
defx * (U8 U8 -> U8)
defx / (U8 U8 -> U8)
defx % (U8 U8 -> U8)
defx to_u64 (U8 -> U64)
def to_string (U8 -> String) \{ to_u64 u64::to_string }
defx gt (U8 U8 -> Boolean)
defx lt (U8 U8 -> Boolean)
defx = (U8 U8 -> Boolean)
defx != (U8 U8 -> Boolean)