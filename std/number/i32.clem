import std::list
import std::number::i64
import std::boolean(Boolean)

defx + (I32 I32 -> I32)
defx - (I32 I32 -> I32)
defx * (I32 I32 -> I32)
defx / (I32 I32 -> I32)
defx % (I32 I32 -> I32)
defx %i8 (I32 I8 -> I8)
defx %i16 (I32 I16 -> I16)
defx to_i64 (I32 -> I64)
def to_string (I32 -> String) \{ to_i64 i64::to_string }
defx gt (I32 I32 -> Boolean)
defx lt (I32 I32 -> Boolean)
defx = (I32 I32 -> Boolean)
defx != (I32 I32 -> Boolean)