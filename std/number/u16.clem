import std::list
import std::number::u64
import std::boolean(Boolean)

defx + (U16 U16 -> U16)
defx - (U16 U16 -> U16)
defx * (U16 U16 -> U16)
defx / (U16 U16 -> U16)
defx % (U16 U16 -> U16)
defx %u8 (U16 U8 -> U8)
defx to_u64 (U16 -> U64)
def to_string (U16 -> String) \{ to_u64 u64::to_string }
defx gt (U16 U16 -> Boolean)
defx lt (U16 U16 -> Boolean)
defx = (U16 U16 -> Boolean)
defx != (U16 U16 -> Boolean)