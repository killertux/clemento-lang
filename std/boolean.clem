import std::stack(drop touch)

type Boolean {
    False True
}

def not (Boolean -> Boolean) \{
    match {
        True -> False
        False -> True
    }
}

def && (Boolean Boolean -> Boolean) \{
    match {
        True -> touch
        False -> { drop False }
    }
}

def || (Boolean Boolean -> Boolean) \{
    match {
        True -> { drop True }
        False -> touch
    }
}
